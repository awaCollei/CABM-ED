text = "这是为了防止例如设备损坏等意外情况
设计的备份手段，由于服务器性能有限，
仅会上传核心存档数据"
clip_text = true

[node name="Note2" type="Label" parent="MainHBox/RightPanel"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.14622062, 0.1494484, 1)
theme_override_font_sizes/font_size = 16
text = "以下数据不会被包含：保存的语音、部分配置
